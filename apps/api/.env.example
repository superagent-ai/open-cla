NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
ADMIN_WEB_URL=http://localhost:3001

# Any Postgres-compatible provider works. Neon is the recommended initial DB.
DATABASE_URL=postgres://user:password@host:5432/superagent_cla?sslmode=require
DATABASE_MIGRATION_URL=postgres://user:password@host:5432/superagent_cla?sslmode=require

GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret
GITHUB_CLIENT_ID=Iv1.example
GITHUB_CLIENT_SECRET=replace-with-client-secret

# Optional but recommended for production personal signing.
# Create a separate GitHub OAuth App with no requested scopes to avoid the
# GitHub App user authorization "act on your behalf" prompt.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Minimum 32 characters.
SESSION_SECRET=replace-with-at-least-32-characters
DEFAULT_CLA_TEMPLATE_NAME=individual-v1
